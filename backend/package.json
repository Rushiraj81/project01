    "express": "^4.18.2",
    "express-rate-limit": "^6.7.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.1",
    "mqtt": "^5.0.0",
    "node-cron": "^3.0.2",
    "redis": "^4.6.7",
    "socket.io": "^4.7.2",
    "winston": "^3.9.0",
    "zod": "^3.21.4",
    "crypto": "^1.0.1",
    "nodemailer": "^6.9.3",
    "multer": "^1.4.5-lts.1",
